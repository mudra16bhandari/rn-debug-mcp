{
    "name": "@rn-debug-mcp/server",
    "version": "1.0.1",
    "description": "MCP Server for React Native runtime debugging",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "rn-debug-mcp-server": "./dist/index.js",
        "server": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "license": "MIT",
    "scripts": {
        "build": "tsc",
        "prepublishOnly": "npm run build",
        "dev": "ts-node src/index.ts",
        "dev:standalone": "ts-node src/standalone.ts",
        "dev:fresh": "npm run free-ports && npm run dev:standalone",
        "free-ports": "lsof -ti :4567,4568 | xargs kill -9 2>/dev/null || true",
        "test": "jest"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "express": "^4.18.0",
        "ws": "^8.16.0",
        "zod": "^3.22.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.0",
        "@types/node": "^20.0.0",
        "@types/ws": "^8.5.0",
        "ts-node": "^10.9.0",
        "typescript": "^5.3.0"
    }
}
