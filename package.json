{
    "name": "rn-debug-mcp-root",
    "version": "1.0.1",
    "description": "React Native Runtime Debugging MCP Monorepo",
    "private": true,
    "license": "MIT",
    "author": "Mudra Bhandari",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "npm run build --workspaces",
        "dev:server": "npm run dev --workspace=@rn-debug-mcp/server",
        "test": "jest",
        "test:watch": "jest --watch",
        "lint": "eslint 'packages/**/*.{ts,tsx,js}'",
        "format": "prettier --write 'packages/**/*.{ts,tsx,js,json,md}'"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.3.0",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "eslint": "^8.57.1",
        "jest": "^29.7.0",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.0"
    }
}